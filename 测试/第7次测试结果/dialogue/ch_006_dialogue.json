[
  {
    "id": "dl_0024",
    "scene_id": "scene_011",
    "character_id": "char_高令宁",
    "line": "送到窑子里去了。",
    "subtext": "她故意用最恶毒、最能刺痛沈词的话激怒他，借此反击他对那个婢女的偏爱，并试探自己在他心中的分量。",
    "emotion_intensity": 0.84,
    "order": 1
  },
  {
    "id": "dl_0025",
    "scene_id": "scene_011",
    "character_id": "char_沈词",
    "line": "你真以为沈家全由你做主了？",
    "subtext": "他在震怒中宣示权威，指责高令宁越界处置他在意的人，实质是在维护自己对沈家的控制和对那婢女的庇护。",
    "emotion_intensity": 0.9,
    "order": 2
  },
  {
    "id": "dl_0026",
    "scene_id": "scene_011",
    "character_id": "char_沈词",
    "line": "若非看你为我生下了睿儿，我定要休了你，绝不让你这种毒妇祸害我沈家。",
    "subtext": "他把高令宁的价值压缩为生育沈睿，借羞辱和威胁发泄愤怒，也是在为自己对她长期的不满寻找正当性。",
    "emotion_intensity": 0.95,
    "order": 3
  },
  {
    "id": "dl_0027",
    "scene_id": "scene_011",
    "character_id": "char_高令宁",
    "line": "休我？",
    "subtext": "她并非真的发问，而是冷笑着质疑他的资格与立场，表示自己对这份威胁毫不服气。",
    "emotion_intensity": 0.73,
    "order": 4
  },
  {
    "id": "dl_0028",
    "scene_id": "scene_011",
    "character_id": "char_高令宁",
    "line": "你扪心自问，我可有半点对不住你沈家？没有我为你打理产业，打点亲朋，你能在朝中心无旁骛地为官？",
    "subtext": "她在申明自己对沈家的付出与功劳，控诉沈词忘恩负义，也是在捍卫自己作为正妻和主母的正当位置。",
    "emotion_intensity": 0.88,
    "order": 5
  },
  {
    "id": "dl_0029",
    "scene_id": "scene_011",
    "character_id": "char_沈词",
    "line": "谁知道你私下里做了多少孽。",
    "subtext": "他并无确凿回应，只是用道德指控反击她的质问，将所有怨恨和怀疑都投射到她身上。",
    "emotion_intensity": 0.82,
    "order": 6
  },
  {
    "id": "dl_0030",
    "scene_id": "scene_011",
    "character_id": "char_高令宁",
    "line": "沈词，你真不要脸。",
    "subtext": "她撕破体面，直指他虚伪自私，表达长期积压的不屑与怨毒。",
    "emotion_intensity": 0.91,
    "order": 7
  },
  {
    "id": "dl_0031",
    "scene_id": "scene_011",
    "character_id": "char_高令宁",
    "line": "祸害了我，祸害了陆姝仪，还想祸害别人？若不是睿儿，你以为我愿意与你过到今天？",
    "subtext": "她把婚姻中的痛苦彻底摊开，指控沈词毁掉了两个女人的人生，并表明自己维持这段关系只是为了孩子。",
    "emotion_intensity": 0.96,
    "order": 8
  },
  {
    "id": "dl_0032",
    "scene_id": "scene_011",
    "character_id": "char_高令宁",
    "line": "我看陆姝仪就是被你克死的……",
    "subtext": "她以最狠毒的方式把陆姝仪之死归咎于沈词，意在彻底刺穿他最深的伤口。",
    "emotion_intensity": 0.98,
    "order": 9
  },
  {
    "id": "dl_0033",
    "scene_id": "scene_013",
    "character_id": "char_沈词",
    "line": "就叫静好吧。",
    "subtext": "他在短暂温情中试图为未出生的孩子命名，也借此修补与高令宁的关系，寄托对家庭安稳的愿望。",
    "emotion_intensity": 0.58,
    "order": 10
  },
  {
    "id": "dl_0034",
    "scene_id": "scene_013",
    "character_id": "char_沈词",
    "line": "琴瑟在御，莫不静好。",
    "subtext": "他引用诗句赋名，表面是在说名字由来，实则流露出对夫妻和顺、家室圆满的渴望。",
    "emotion_intensity": 0.51,
    "order": 11
  },
  {
    "id": "dl_0035",
    "scene_id": "scene_015",
    "character_id": "char_高令宁",
    "line": "罢了，沈公子明日便来提亲吧。",
    "subtext": "她在看透强求无用后选择妥协，不是出于欣喜，而是疲惫地接受这段注定纠缠的关系进入下一步。",
    "emotion_intensity": 0.42,
    "order": 12
  },
  {
    "id": "dl_0036",
    "scene_id": "scene_015",
    "character_id": "char_沈词",
    "line": "你又想做什么？",
    "subtext": "他对她忽然松口并不信任，第一反应是怀疑她另有盘算，显示两人之间根深蒂固的戒备。",
    "emotion_intensity": 0.49,
    "order": 13
  },
  {
    "id": "dl_0037",
    "scene_id": "scene_015",
    "character_id": "char_高令宁",
    "line": "成亲之后，还望公子说话算话。",
    "subtext": "她答应婚事的前提是对方履行先前承诺，语气平静却带着明确边界，说明这不是示爱，而是一场有条件的交换。",
    "emotion_intensity": 0.38,
    "order": 14
  }
]