{
  "count": 191,
  "updated_at": "2026-03-09T00:46:39",
  "entries": [
    {
      "id": "dl_0016",
      "scene_id": "scene_001",
      "character_id": "char_高父",
      "line": "被沈家看中，是小女的福气。"
    },
    {
      "id": "dl_0017",
      "scene_id": "scene_001",
      "character_id": "char_媒人",
      "line": "高姑娘，这是……"
    },
    {
      "id": "dl_0018",
      "scene_id": "scene_001",
      "character_id": "char_高令宁",
      "line": "聘礼太薄，我不满意。"
    },
    {
      "id": "dl_0019",
      "scene_id": "scene_001",
      "character_id": "char_高父",
      "line": "胡闹！沈家什么门第，岂容你拿乔？"
    },
    {
      "id": "dl_0020",
      "scene_id": "scene_001",
      "character_id": "char_媒人",
      "line": "高小姐，此时不可闹姑娘脾气，这门亲事不易，若沈家一气之下反悔……"
    },
    {
      "id": "dl_0021",
      "scene_id": "scene_001",
      "character_id": "char_高令宁",
      "line": "我便是这般贪慕虚荣的人，沈公子可要退亲？"
    },
    {
      "id": "dl_0022",
      "scene_id": "scene_001",
      "character_id": "char_沈词",
      "line": "姑娘说笑了。"
    },
    {
      "id": "dl_0023",
      "scene_id": "scene_001",
      "character_id": "char_沈词",
      "line": "我回去会再和父母商议聘礼，必定让姑娘满意。"
    },
    {
      "id": "dl_0003",
      "scene_id": "scene_000",
      "character_id": "char_高父",
      "line": "你发什么疯？"
    },
    {
      "id": "dl_0004",
      "scene_id": "scene_000",
      "character_id": "char_高父",
      "line": "之前你不是夸沈家哥乃是良婿之选，若能嫁给他此生无憾吗？怎么今日给他下这么大个脸？"
    },
    {
      "id": "dl_0005",
      "scene_id": "scene_000",
      "character_id": "char_高父",
      "line": "你今日给了沈公子好大一个难堪……"
    },
    {
      "id": "dl_0006",
      "scene_id": "scene_000",
      "character_id": "char_高令宁",
      "line": "我知道。"
    },
    {
      "id": "dl_0007",
      "scene_id": "scene_000",
      "character_id": "char_高父",
      "line": "你若真是不想嫁，为父找个由头回绝了便是，何须如此？"
    },
    {
      "id": "dl_0008",
      "scene_id": "scene_000",
      "character_id": "char_高令宁",
      "line": "谁说我不想嫁？"
    },
    {
      "id": "dl_0009",
      "scene_id": "scene_000",
      "character_id": "char_高令宁",
      "line": "我一定要嫁。"
    },
    {
      "id": "dl_0000",
      "scene_id": "scene_021",
      "character_id": "char_沈睿",
      "line": "你究竟是我沈家妇，还是高家女？"
    },
    {
      "id": "dl_0001",
      "scene_id": "scene_021",
      "character_id": "char_沈睿",
      "line": "你这般防我，可曾把我当作你的夫婿？"
    },
    {
      "id": "dl_0002",
      "scene_id": "scene_023",
      "character_id": "char_沈睿",
      "line": "怎么，又想从我身上得到什么？"
    },
    {
      "id": "dl_0071",
      "scene_id": "scene_016",
      "character_id": "char_高父",
      "line": "沈家势大，只怕你嫁过去会受委屈。"
    },
    {
      "id": "dl_0072",
      "scene_id": "scene_016",
      "character_id": "char_高父",
      "line": "为父生养你十余年，不求你高嫁为家族争光，但求你觅得良人，平安喜乐度过此生。"
    },
    {
      "id": "dl_0073",
      "scene_id": "scene_017",
      "character_id": "char_高令宁",
      "line": "爹爹年纪大了，官居四品，是时候思退了，别再掺合朝堂的浑水了，否则稍有不慎，便是抄家灭门之灾。"
    },
    {
      "id": "dl_0074",
      "scene_id": "scene_018",
      "character_id": "char_沈词",
      "line": "我以为，你不算个好妻子，但还算个好母亲。"
    },
    {
      "id": "dl_0075",
      "scene_id": "scene_018",
      "character_id": "char_沈词",
      "line": "这一世若你我不成亲，便等于再杀睿儿一次。"
    },
    {
      "id": "dl_0076",
      "scene_id": "scene_019",
      "character_id": "char_高令宁",
      "line": "我可以嫁。"
    },
    {
      "id": "dl_0077",
      "scene_id": "scene_019",
      "character_id": "char_高令宁",
      "line": "但是，你要先处理好那位表小姐。"
    },
    {
      "id": "dl_0078",
      "scene_id": "scene_019",
      "character_id": "char_沈词",
      "line": "你何必对姝仪苦苦相逼？"
    },
    {
      "id": "dl_0079",
      "scene_id": "scene_019",
      "character_id": "char_沈词",
      "line": "我与她只是自小相伴之谊。"
    },
    {
      "id": "dl_0080",
      "scene_id": "scene_019",
      "character_id": "char_沈词",
      "line": "你不让我纳她，我便没再提过此事，你可曾见过我与她有逾矩之处？"
    },
    {
      "id": "dl_0081",
      "scene_id": "scene_019",
      "character_id": "char_沈词",
      "line": "若是你为我的妻子……"
    },
    {
      "id": "dl_0082",
      "scene_id": "scene_019",
      "character_id": "char_沈词",
      "line": "姝仪的事，我可以答应你，但你也莫要得意。"
    },
    {
      "id": "dl_0083",
      "scene_id": "scene_019",
      "character_id": "char_沈词",
      "line": "你我性子相冲，前世日日怨怼，让睿儿死前还在为我们担心。"
    },
    {
      "id": "dl_0084",
      "scene_id": "scene_019",
      "character_id": "char_沈词",
      "line": "成亲后，睿儿一出生，我会给你足以傍身的财产，我们便和离，别的事情你别痴心妄想。"
    },
    {
      "id": "dl_0085",
      "scene_id": "scene_019",
      "character_id": "char_高令宁",
      "line": "本该如此。"
    },
    {
      "id": "dl_0086",
      "scene_id": "scene_019",
      "character_id": "char_沈词",
      "line": "你莫要使手段纠缠。"
    },
    {
      "id": "dl_0087",
      "scene_id": "scene_019",
      "character_id": "char_高令宁",
      "line": "谁纠缠谁是狗。"
    },
    {
      "id": "dl_0054",
      "scene_id": "scene_028",
      "character_id": "char_蒋晟",
      "line": "是我没护好你。"
    },
    {
      "id": "dl_0055",
      "scene_id": "scene_028",
      "character_id": "char_蒋晟",
      "line": "方才有同窗寻我，推脱不得，我才……"
    },
    {
      "id": "dl_0056",
      "scene_id": "scene_028",
      "character_id": "char_高令宁",
      "line": "我们回家吧。"
    },
    {
      "id": "dl_0057",
      "scene_id": "scene_029",
      "character_id": "char_旁白",
      "line": "二位留步。"
    },
    {
      "id": "dl_0058",
      "scene_id": "scene_029",
      "character_id": "char_旁白",
      "line": "还望高姑娘，言出必行。"
    },
    {
      "id": "dl_0059",
      "scene_id": "scene_029",
      "character_id": "char_高令宁",
      "line": "公子还是先操心好表小姐的婚事，再来提亲吧。"
    },
    {
      "id": "dl_0060",
      "scene_id": "scene_029",
      "character_id": "char_旁白",
      "line": "你何必如此苦苦相逼？"
    },
    {
      "id": "dl_0061",
      "scene_id": "scene_029",
      "character_id": "char_旁白",
      "line": "时间来不及为姝仪慢慢择婿，你就不能退一步吗？"
    },
    {
      "id": "dl_0062",
      "scene_id": "scene_029",
      "character_id": "char_高令宁",
      "line": "不退。"
    },
    {
      "id": "dl_0063",
      "scene_id": "scene_030",
      "character_id": "char_陆姝仪",
      "line": "高小姐……"
    },
    {
      "id": "dl_0064",
      "scene_id": "scene_030",
      "character_id": "char_陆姝仪",
      "line": "我与兄长真的无男女之情，求你，求你可怜可怜我，让我暂且留在沈家……就拿我当奴婢，当宠物……"
    },
    {
      "id": "dl_0065",
      "scene_id": "scene_030",
      "character_id": "char_旁白",
      "line": "姝仪，你这是做什么？"
    },
    {
      "id": "dl_0066",
      "scene_id": "scene_030",
      "character_id": "char_旁白",
      "line": "有我在，没人能赶你走。"
    },
    {
      "id": "dl_0067",
      "scene_id": "scene_031",
      "character_id": "char_陆姝仪",
      "line": "有些事，是强求不来的。"
    },
    {
      "id": "dl_0068",
      "scene_id": "scene_031",
      "character_id": "char_陆姝仪",
      "line": "恰如你是他的妻子，可得到的疼爱，却只是我手头缝里流出来的一点。"
    },
    {
      "id": "dl_0069",
      "scene_id": "scene_031",
      "character_id": "char_陆姝仪",
      "line": "你辛辛苦苦追求的，我轻而易举便得到了。"
    },
    {
      "id": "dl_0070",
      "scene_id": "scene_031",
      "character_id": "char_陆姝仪",
      "line": "高姑娘，你不觉得自己很可笑吗？"
    },
    {
      "id": "dl_0024",
      "scene_id": "scene_011",
      "character_id": "char_高令宁",
      "line": "送到窑子里去了。"
    },
    {
      "id": "dl_0025",
      "scene_id": "scene_011",
      "character_id": "char_沈词",
      "line": "你真以为沈家全由你做主了？"
    },
    {
      "id": "dl_0026",
      "scene_id": "scene_011",
      "character_id": "char_沈词",
      "line": "若非看你为我生下了睿儿，我定要休了你，绝不让你这种毒妇祸害我沈家。"
    },
    {
      "id": "dl_0027",
      "scene_id": "scene_011",
      "character_id": "char_高令宁",
      "line": "休我？"
    },
    {
      "id": "dl_0028",
      "scene_id": "scene_011",
      "character_id": "char_高令宁",
      "line": "你扪心自问，我可有半点对不住你沈家？没有我为你打理产业，打点亲朋，你能在朝中心无旁骛地为官？"
    },
    {
      "id": "dl_0029",
      "scene_id": "scene_011",
      "character_id": "char_沈词",
      "line": "谁知道你私下里做了多少孽。"
    },
    {
      "id": "dl_0030",
      "scene_id": "scene_011",
      "character_id": "char_高令宁",
      "line": "沈词，你真不要脸。"
    },
    {
      "id": "dl_0031",
      "scene_id": "scene_011",
      "character_id": "char_高令宁",
      "line": "祸害了我，祸害了陆姝仪，还想祸害别人？若不是睿儿，你以为我愿意与你过到今天？"
    },
    {
      "id": "dl_0032",
      "scene_id": "scene_011",
      "character_id": "char_高令宁",
      "line": "我看陆姝仪就是被你克死的……"
    },
    {
      "id": "dl_0033",
      "scene_id": "scene_013",
      "character_id": "char_沈词",
      "line": "就叫静好吧。"
    },
    {
      "id": "dl_0034",
      "scene_id": "scene_013",
      "character_id": "char_沈词",
      "line": "琴瑟在御，莫不静好。"
    },
    {
      "id": "dl_0035",
      "scene_id": "scene_015",
      "character_id": "char_高令宁",
      "line": "罢了，沈公子明日便来提亲吧。"
    },
    {
      "id": "dl_0036",
      "scene_id": "scene_015",
      "character_id": "char_沈词",
      "line": "你又想做什么？"
    },
    {
      "id": "dl_0037",
      "scene_id": "scene_015",
      "character_id": "char_高令宁",
      "line": "成亲之后，还望公子说话算话。"
    },
    {
      "id": "dl_0038",
      "scene_id": "scene_002",
      "character_id": "char_高父",
      "line": "沈家豪门显贵，又是京中数一数二的富户，你嫁过去若受轻视可怎么办？"
    },
    {
      "id": "dl_0039",
      "scene_id": "scene_002",
      "character_id": "char_高令宁",
      "line": "无妨。"
    },
    {
      "id": "dl_0040",
      "scene_id": "scene_002",
      "character_id": "char_高令宁",
      "line": "父亲只当女儿去沈家暂住一段时间，早晚要回来的。"
    },
    {
      "id": "dl_0041",
      "scene_id": "scene_002",
      "character_id": "char_高父",
      "line": "齐大非偶，"
    },
    {
      "id": "dl_0042",
      "scene_id": "scene_002",
      "character_id": "char_高父",
      "line": "你不必逼着自己一定让沈家满意，受了委屈便和离回家，为父再另为你安排亲事。"
    },
    {
      "id": "dl_0043",
      "scene_id": "scene_004",
      "character_id": "char_沈词",
      "line": "这张嘴不是挺厉害吗？怎么现在连一句完整的话都说不出？"
    },
    {
      "id": "dl_0044",
      "scene_id": "scene_004",
      "character_id": "char_沈词",
      "line": "夫人，这一世在床榻之上，你还是这么没用啊。"
    },
    {
      "id": "dl_0045",
      "scene_id": "scene_004",
      "character_id": "char_高令宁",
      "line": "……畜生。"
    },
    {
      "id": "dl_0046",
      "scene_id": "scene_004",
      "character_id": "char_沈词",
      "line": "要不是睿儿，你以为我想碰你？"
    },
    {
      "id": "dl_0047",
      "scene_id": "scene_004",
      "character_id": "char_沈词",
      "line": "再敢骂人，信不信我让他们进来再换一次水？"
    },
    {
      "id": "dl_0048",
      "scene_id": "scene_004",
      "character_id": "char_高令宁",
      "line": "再快点吧，我困了。"
    },
    {
      "id": "dl_0049",
      "scene_id": "scene_005",
      "character_id": "char_陆姝仪的婢女",
      "line": "公子，小姐喝醉了酒，直说心口痛，您……您去看看吧。"
    },
    {
      "id": "dl_0050",
      "scene_id": "scene_005",
      "character_id": "char_高令宁",
      "line": "你去吧。"
    },
    {
      "id": "dl_0051",
      "scene_id": "scene_005",
      "character_id": "char_高令宁",
      "line": "也不必回来了。"
    },
    {
      "id": "dl_0052",
      "scene_id": "scene_005",
      "character_id": "char_沈词",
      "line": "怎么，又想等我姝仪那里后，再去我父亲母亲前告状？"
    },
    {
      "id": "dl_0053",
      "scene_id": "scene_005",
      "character_id": "char_高令宁",
      "line": "你我早晚要和离，我费那心思做什么？"
    },
    {
      "id": "dl_0088",
      "scene_id": "scene_007",
      "character_id": "char_高令宁",
      "line": "若你实在心疼，不如便将她纳进来吧。"
    },
    {
      "id": "dl_0089",
      "scene_id": "scene_007",
      "character_id": "char_高令宁",
      "line": "你此时倒做上好人了，"
    },
    {
      "id": "dl_0090",
      "scene_id": "scene_007",
      "character_id": "char_高令宁",
      "line": "如今姝仪是我名义上妹妹……"
    },
    {
      "id": "dl_0091",
      "scene_id": "scene_007",
      "character_id": "char_高令宁",
      "line": "对外宣称她病逝，私下接入府中，不就成了？"
    },
    {
      "id": "dl_0092",
      "scene_id": "scene_007",
      "character_id": "char_高令宁",
      "line": "等你我一和离，你给她扶正或是不再娶妻，都皆大欢喜。"
    },
    {
      "id": "dl_0093",
      "scene_id": "scene_007",
      "character_id": "char_高令宁",
      "line": "我与姝仪，并无男女之情。"
    },
    {
      "id": "dl_0094",
      "scene_id": "scene_007",
      "character_id": "char_高令宁",
      "line": "从始至终，我只是想要她余生顺遂，是你一直扭曲我们的感情，怨怼于我。"
    },
    {
      "id": "dl_0095",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "你这般心疼睿儿，来日生下他，只怕是要在沈府赖一辈子。"
    },
    {
      "id": "dl_0096",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "你想多了。"
    },
    {
      "id": "dl_0097",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "我做完月子便走，不会纠缠。"
    },
    {
      "id": "dl_0098",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "那沈睿……"
    },
    {
      "id": "dl_0099",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "有孩子的夫妇和离得也不少，睿儿能理解，无论你是否续娶，我都会定时来看他。"
    },
    {
      "id": "dl_0100",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "高令宁，你又说气话。"
    },
    {
      "id": "dl_0101",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "你这边和离，我便立即娶姝仪入府……"
    },
    {
      "id": "dl_0102",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "有何不妥？"
    },
    {
      "id": "dl_0103",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "你这般恨我，岂能看着我余生和姝仪和和美美？"
    },
    {
      "id": "dl_0104",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "你放心，我想开了，以后都不会恨你了。"
    },
    {
      "id": "dl_0105",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "高令宁，"
    },
    {
      "id": "dl_0106",
      "scene_id": "scene_008",
      "character_id": "char_高令宁",
      "line": "谁准你想开了？"
    },
    {
      "id": "dl_0010",
      "scene_id": "scene_036",
      "character_id": "char_沈睿",
      "line": "其实上一世，我有许多对不住你的地方。"
    },
    {
      "id": "dl_0011",
      "scene_id": "scene_037",
      "character_id": "char_高父",
      "line": "姑爷看起来，是把你捧在心尖上的。"
    },
    {
      "id": "dl_0012",
      "scene_id": "scene_038",
      "character_id": "char_高父",
      "line": "如今我看你们感情甚好，又有孩子，那位表小姐也即将出嫁，不如便这般过下去吧。"
    },
    {
      "id": "dl_0013",
      "scene_id": "scene_038",
      "character_id": "char_高父",
      "line": "至亲至疏夫妻，世间夫妻不大都如此吗？"
    },
    {
      "id": "dl_0014",
      "scene_id": "scene_038",
      "character_id": "char_高令宁",
      "line": "爹爹不觉得我和姑爷性子太左，难以磨合吗？"
    },
    {
      "id": "dl_0015",
      "scene_id": "scene_038",
      "character_id": "char_高父",
      "line": "先前我正是担心，才不希望你嫁入沈家，不过我未曾想，你们成亲后，和之前比起来，竟都变了许多。"
    },
    {
      "id": "dl_0132",
      "scene_id": "scene_032",
      "character_id": "char_陆姝仪",
      "line": "夫人，您便这般恨我吗？"
    },
    {
      "id": "dl_0133",
      "scene_id": "scene_032",
      "character_id": "char_陆姝仪",
      "line": "我不日将成婚，您设计我失贞，是要我非死不可吗？"
    },
    {
      "id": "dl_0134",
      "scene_id": "scene_032",
      "character_id": "char_陆姝仪",
      "line": "夫人，满高府都是您的人，我只是沈家的孤女，无权无势，自然您想要什么证据都有。"
    },
    {
      "id": "dl_0135",
      "scene_id": "scene_032",
      "character_id": "char_陆姝仪",
      "line": "兄长，难道你觉得我是个不知廉耻去勾引男人的货色吗？"
    },
    {
      "id": "dl_0136",
      "scene_id": "scene_032",
      "character_id": "char_高令宁",
      "line": "沈词！"
    },
    {
      "id": "dl_0137",
      "scene_id": "scene_032",
      "character_id": "char_蒋晟",
      "line": "明日，你最好上门提亲。"
    },
    {
      "id": "dl_0138",
      "scene_id": "scene_032",
      "character_id": "char_高令宁",
      "line": "你把话说清楚再走。"
    },
    {
      "id": "dl_0139",
      "scene_id": "scene_032",
      "character_id": "char_蒋晟",
      "line": "松手。"
    },
    {
      "id": "dl_0140",
      "scene_id": "scene_032",
      "character_id": "char_蒋晟",
      "line": "你现在还怀着孕，我不想与你说这些。"
    },
    {
      "id": "dl_0141",
      "scene_id": "scene_032",
      "character_id": "char_蒋晟",
      "line": "我本以为你变好了，没想到还这么让我失望了。"
    },
    {
      "id": "dl_0142",
      "scene_id": "scene_032",
      "character_id": "char_蒋晟",
      "line": "从头到尾，你都是这般恶毒跋扈的妇人。"
    },
    {
      "id": "dl_0143",
      "scene_id": "scene_033",
      "character_id": "char_高令宁",
      "line": "事情不调查清楚，今日你们谁都别想走。"
    },
    {
      "id": "dl_0144",
      "scene_id": "scene_033",
      "character_id": "char_高令宁",
      "line": "若在高家调查不清，那我就去登京兆府，敲登门鼓，要个公道！"
    },
    {
      "id": "dl_0145",
      "scene_id": "scene_033",
      "character_id": "char_蒋晟",
      "line": "你疯了！"
    },
    {
      "id": "dl_0146",
      "scene_id": "scene_033",
      "character_id": "char_蒋晟",
      "line": "你非要闹得满城风雨，逼死了姝仪才罢休吗？"
    },
    {
      "id": "dl_0147",
      "scene_id": "scene_033",
      "character_id": "char_蒋晟",
      "line": "这一世姝仪若再为你而死，信不信我杀了你？"
    },
    {
      "id": "dl_0148",
      "scene_id": "scene_033",
      "character_id": "char_陆姝仪",
      "line": "你怎么敢打阿词？"
    },
    {
      "id": "dl_0149",
      "scene_id": "scene_033",
      "character_id": "char_高父",
      "line": "女儿！"
    },
    {
      "id": "dl_0150",
      "scene_id": "scene_034",
      "character_id": "char_稳婆",
      "line": "沈大人，夫人急火攻心，早产加难产。"
    },
    {
      "id": "dl_0151",
      "scene_id": "scene_034",
      "character_id": "char_稳婆",
      "line": "只怕这孩子……未必能顺利生下来。"
    },
    {
      "id": "dl_0152",
      "scene_id": "scene_034",
      "character_id": "char_稳婆",
      "line": "届时保大保小，还得等您拿主意啊。"
    },
    {
      "id": "dl_0153",
      "scene_id": "scene_034",
      "character_id": "char_稳婆",
      "line": "沈大人……求求您给个主意吧，到底是保大人还是保孩子啊？"
    },
    {
      "id": "dl_0154",
      "scene_id": "scene_035",
      "character_id": "char_旁白",
      "line": "高令宁……"
    },
    {
      "id": "dl_0155",
      "scene_id": "scene_035",
      "character_id": "char_稳婆",
      "line": "什么？"
    },
    {
      "id": "dl_0156",
      "scene_id": "scene_035",
      "character_id": "char_蒋晟",
      "line": "我要高令宁。"
    },
    {
      "id": "dl_0157",
      "scene_id": "scene_035",
      "character_id": "char_蒋晟",
      "line": "我要她活着。"
    },
    {
      "id": "dl_0158",
      "scene_id": "scene_035",
      "character_id": "char_稳婆",
      "line": "沈大人，快来看看小千金，漂亮得很呢！"
    },
    {
      "id": "dl_0159",
      "scene_id": "scene_035",
      "character_id": "char_蒋晟",
      "line": "你说什么？"
    },
    {
      "id": "dl_0160",
      "scene_id": "scene_048",
      "character_id": "char_沈睿",
      "line": "娘，这是儿子亲自熬的，求您喝一点吧。"
    },
    {
      "id": "dl_0161",
      "scene_id": "scene_048",
      "character_id": "char_沈睿",
      "line": "妹妹……走后，您和爹爹总是把自己关起来，不吃不喝，儿子真的很担心您的身体。"
    },
    {
      "id": "dl_0162",
      "scene_id": "scene_048",
      "character_id": "char_沈睿",
      "line": "都是儿子不好。"
    },
    {
      "id": "dl_0163",
      "scene_id": "scene_048",
      "character_id": "char_高令宁",
      "line": "与你何干？"
    },
    {
      "id": "dl_0164",
      "scene_id": "scene_048",
      "character_id": "char_沈睿",
      "line": "若非为了儿子，爹娘早就和离，各自生活，而非像现在这般互相将就。"
    },
    {
      "id": "dl_0165",
      "scene_id": "scene_048",
      "character_id": "char_沈睿",
      "line": "娘亲为我，受了太多委屈。"
    },
    {
      "id": "dl_0166",
      "scene_id": "scene_048",
      "character_id": "char_沈睿",
      "line": "若有来生，娘亲别再生下我，让妹妹代替我承欢膝下，侍奉您终老。"
    },
    {
      "id": "dl_0167",
      "scene_id": "scene_049",
      "character_id": "char_高父",
      "line": "高家虽然门第低，却也并非好欺负的，贵公子与义妹关系暧昧，差点害得发妻一事两命，这若传出去，沈公子的官"
    },
    {
      "id": "dl_0168",
      "scene_id": "scene_049",
      "character_id": "char_沈母",
      "line": "可是，昭昭毕竟是我们沈家的血脉……"
    },
    {
      "id": "dl_0169",
      "scene_id": "scene_049",
      "character_id": "char_高父",
      "line": "我高家还养得起一个小姑娘，"
    },
    {
      "id": "dl_0170",
      "scene_id": "scene_049",
      "character_id": "char_高父",
      "line": "两个孩子和离后，昭昭归高家。"
    },
    {
      "id": "dl_0171",
      "scene_id": "scene_049",
      "character_id": "char_高父",
      "line": "沈家若执意纠缠，那便闹上公堂，鱼死网破。"
    },
    {
      "id": "dl_0172",
      "scene_id": "scene_050",
      "character_id": "char_沈词",
      "line": "爹，令宁不会与我和离的。"
    },
    {
      "id": "dl_0173",
      "scene_id": "scene_050",
      "character_id": "char_沈词",
      "line": "至于陆姝仪，她已经嫁给蒋晟为妇，我也告诫了她，婚后不得再回沈府。"
    },
    {
      "id": "dl_0174",
      "scene_id": "scene_050",
      "character_id": "char_沈词",
      "line": "爹，我与令宁已有子嗣，应共同抚育她长大……孩子怎能没有爹爹？"
    },
    {
      "id": "dl_0175",
      "scene_id": "scene_050",
      "character_id": "char_高父",
      "line": "不必，"
    },
    {
      "id": "dl_0176",
      "scene_id": "scene_050",
      "character_id": "char_高父",
      "line": "我的女儿不愁没人要，我已经备好了赘婿人选，昭昭同样不会缺爹爹疼爱。"
    },
    {
      "id": "dl_0177",
      "scene_id": "scene_051",
      "character_id": "char_沈词",
      "line": "高令宁，你什么意思？"
    },
    {
      "id": "dl_0178",
      "scene_id": "scene_051",
      "character_id": "char_高令宁",
      "line": "按照我们约定好的，和离。"
    },
    {
      "id": "dl_0179",
      "scene_id": "scene_051",
      "character_id": "char_高令宁",
      "line": "我们性情不合，强行活在一处，只会互相折磨。"
    },
    {
      "id": "dl_0180",
      "scene_id": "scene_051",
      "character_id": "char_沈词",
      "line": "别装了。"
    },
    {
      "id": "dl_0181",
      "scene_id": "scene_051",
      "character_id": "char_沈词",
      "line": "我不信你肯放过我。"
    },
    {
      "id": "dl_0182",
      "scene_id": "scene_051",
      "character_id": "char_沈词",
      "line": "你忘了前世你死时，说了什么吗？"
    },
    {
      "id": "dl_0183",
      "scene_id": "scene_052",
      "character_id": "char_高令宁",
      "line": "我就算死了……"
    },
    {
      "id": "dl_0184",
      "scene_id": "scene_052",
      "character_id": "char_高令宁",
      "line": "也会一直缠着你，让你痛苦一生。"
    },
    {
      "id": "dl_0185",
      "scene_id": "scene_052",
      "character_id": "char_沈词",
      "line": "我等着。"
    },
    {
      "id": "dl_0186",
      "scene_id": "scene_053",
      "character_id": "char_沈词",
      "line": "高令宁，说话算话。"
    },
    {
      "id": "dl_0187",
      "scene_id": "scene_053",
      "character_id": "char_高令宁",
      "line": "可是我现在真的已经想开了。"
    },
    {
      "id": "dl_0188",
      "scene_id": "scene_053",
      "character_id": "char_高令宁",
      "line": "沈词，我原谅你了，我希望余生你也能觅得良人。"
    },
    {
      "id": "dl_0189",
      "scene_id": "scene_053",
      "character_id": "char_沈词",
      "line": "不可以……"
    },
    {
      "id": "dl_0190",
      "scene_id": "scene_053",
      "character_id": "char_沈词",
      "line": "高令宁，我不要你原谅我。"
    },
    {
      "id": "dl_0107",
      "scene_id": "scene_045",
      "character_id": "char_陆姝仪",
      "line": "我真羡慕你，有亲人相护。"
    },
    {
      "id": "dl_0108",
      "scene_id": "scene_045",
      "character_id": "char_陆姝仪",
      "line": "不似我自小父母离世，寄人篱下，除了阿词，无人肯真心待我。"
    },
    {
      "id": "dl_0109",
      "scene_id": "scene_045",
      "character_id": "char_高令宁",
      "line": "这就是你陷害我的理由？"
    },
    {
      "id": "dl_0110",
      "scene_id": "scene_046",
      "character_id": "char_陆姝仪",
      "line": "高令宁，是我对不住你。"
    },
    {
      "id": "dl_0111",
      "scene_id": "scene_046",
      "character_id": "char_陆姝仪",
      "line": "我曾记恨你太过霸道，不肯容我入府，害得我最后所嫁非人……才投湖自尽，哪怕死，也要让你和沈词之间产生嫌"
    },
    {
      "id": "dl_0112",
      "scene_id": "scene_046",
      "character_id": "char_陆姝仪",
      "line": "蒋晟的事，是我设计。"
    },
    {
      "id": "dl_0113",
      "scene_id": "scene_046",
      "character_id": "char_陆姝仪",
      "line": "既然沈家无人为我做主, 那我只能自己寻个好夫婿, 哪怕……手段下作了些。"
    },
    {
      "id": "dl_0114",
      "scene_id": "scene_046",
      "character_id": "char_陆姝仪",
      "line": "你或许还有退路, 然而我的路只有这一条。"
    },
    {
      "id": "dl_0115",
      "scene_id": "scene_046",
      "character_id": "char_陆姝仪",
      "line": "我知道你厌恶我, 以后不会再出现在你面前。"
    },
    {
      "id": "dl_0116",
      "scene_id": "scene_041",
      "character_id": "char_沈睿",
      "line": "母亲已经为我挑选好一大家闺秀, 不日成亲。"
    },
    {
      "id": "dl_0117",
      "scene_id": "scene_041",
      "character_id": "char_沈睿",
      "line": "那姑娘与我脾气契合, 想来成亲后定能举案齐眉，子孙满堂，和和美美……你若不愿意便写信告知我, 我可以"
    },
    {
      "id": "dl_0118",
      "scene_id": "scene_041",
      "character_id": "char_高令宁",
      "line": "祝你和新夫人百年好合……婚后莫忘寄钱。"
    },
    {
      "id": "dl_0119",
      "scene_id": "scene_041",
      "character_id": "char_昭昭",
      "line": "爹爹！"
    },
    {
      "id": "dl_0120",
      "scene_id": "scene_041",
      "character_id": "char_沈睿",
      "line": "他们是谁？"
    },
    {
      "id": "dl_0121",
      "scene_id": "scene_041",
      "character_id": "char_高令宁",
      "line": "我的新夫婿。"
    },
    {
      "id": "dl_0122",
      "scene_id": "scene_041",
      "character_id": "char_高令宁",
      "line": "客房在里面, 去留随意。"
    },
    {
      "id": "dl_0123",
      "scene_id": "scene_042",
      "character_id": "char_高令宁",
      "line": "沈词, 你有病吗？"
    },
    {
      "id": "dl_0124",
      "scene_id": "scene_042",
      "character_id": "char_旁白",
      "line": "别着凉。"
    },
    {
      "id": "dl_0125",
      "scene_id": "scene_042",
      "character_id": "char_沈睿",
      "line": "令宁, 方才窗外打雷了，我知道你会害怕，就想来陪陪你……"
    },
    {
      "id": "dl_0126",
      "scene_id": "scene_042",
      "character_id": "char_高令宁",
      "line": "我已经有人陪了。"
    },
    {
      "id": "dl_0127",
      "scene_id": "scene_042",
      "character_id": "char_高令宁",
      "line": "你走吧。"
    },
    {
      "id": "dl_0128",
      "scene_id": "scene_043",
      "character_id": "char_沈睿",
      "line": "我不放你, 我在地上陪你。"
    },
    {
      "id": "dl_0129",
      "scene_id": "scene_043",
      "character_id": "char_沈睿",
      "line": "高令宁，你永远别想摆脱我。"
    },
    {
      "id": "dl_0130",
      "scene_id": "scene_043",
      "character_id": "char_沈睿",
      "line": "只要我还活着……"
    },
    {
      "id": "dl_0131",
      "scene_id": "scene_043",
      "character_id": "char_沈睿",
      "line": "我就会恬不知耻地纠缠你一辈子。"
    }
  ]
}