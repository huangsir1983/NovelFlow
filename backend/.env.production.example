# UnrealMake Backend Production Environment Variables
# Copy to .env on production and fill values

# Environment
APP_ENV=production
DEBUG=false

# Database (PostgreSQL required in production)
DATABASE_URL=postgresql+psycopg2://unrealmake:REPLACE_PASSWORD@postgres-host:5432/unrealmake
DB_POOL_SIZE=50
DB_MAX_OVERFLOW=100
DB_POOL_RECYCLE=1800

# Redis / Queue
REDIS_URL=redis://redis-host:6379/0
USE_CELERY_QUEUE=true

# Storage
STORAGE_PROVIDER=oss
STORAGE_LOCAL_DIR=./uploads
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=REPLACE_ACCESS_KEY_ID
OSS_ACCESS_KEY_SECRET=REPLACE_ACCESS_KEY_SECRET
OSS_BUCKET_NAME=replace-bucket-name
OSS_PREFIX=unrealmake

# AI
ANTHROPIC_API_KEY=REPLACE_WITH_SECURE_SECRET
DEFAULT_MODEL=claude-sonnet-4-6

# AI Rate Limit (global)
AI_RPM_LIMIT=500
AI_TPM_LIMIT=800000

# Import / Upload
MAX_CONCURRENT_IMPORTS=100
MAX_UPLOAD_SIZE_MB=50

# Server
HOST=0.0.0.0
PORT=8000

# CORS (array string)
CORS_ORIGINS=["https://your-frontend-domain.com"]
