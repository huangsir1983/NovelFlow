{
  "name": "unrealmake",
  "version": "0.1.0",
  "private": true,
  "description": "虚幻造物 (Unreal Make) — AI-Native visual filmmaking creation engine",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:web": "turbo dev --filter=@unrealmake/web",
    "dev:backend": "cd backend && uvicorn main:app --reload --port 8000",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "three": "^0.183.2"
  }
}
